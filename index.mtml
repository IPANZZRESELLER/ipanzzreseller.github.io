<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mid Ipanzz</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: #0d0d0d;
  color: white;
  text-align: center;
}

.container {
  margin-top: 80px;
}

img {
  width: 110px;
  border-radius: 50%;
  border: 2px solid white;
}

h1 {
  margin: 15px 0 5px;
}

p {
  color: #aaa;
}

.link {
  display: block;
  margin: 12px auto;
  padding: 14px;
  width: 260px;
  background: #1a1a1a;
  border-radius: 12px;
  text-decoration: none;
  color: white;
  transition: 0.3s;
}

.link:hover {
  background: white;
  color: black;
}
</style>
</head>

<body>

<div class="container">
  <img src="https://via.placeholder.com/100" alt="profile">
  <h1>Mid Ipanzz</h1>
  <p>Official Links</p>

  <a class="link" href="#">Instagram</a>
  <a class="link" href="#">TikTok</a>
  <a class="link" href="#">Shopee</a>
</div>

</body>
</html>